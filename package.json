    "framer-motion": "^11.0.0",
    "lucide-react": "^0.453.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "three": "^0.185.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^5.0.4",
